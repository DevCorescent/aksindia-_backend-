PORT=5000
NODE_ENV=development

DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_JWT_EXPIRES_IN=30d

# Single origin (simple setup)
FRONTEND_URL=http://localhost:5173

# Multiple origins comma-separated (production)
# FRONTEND_URLS=https://askindia.in,https://www.askindia.in,http://localhost:5173

# Razorpay (payment gateway)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloudinary (image uploads) — optional, add if using backend upload proxy
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
